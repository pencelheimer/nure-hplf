set dotenv-load

export PORT := "3001"

mod backend
mod frontend
mod mobile

# List all recipes
default:
    just --list

# Install dependencies for all components
install: backend::install frontend::install

# Run backend and frontend dev servers in parallel
[parallel]
dev: backend::dev frontend::dev

# Remove all build artifacts, node_modules, and the database
clean: backend::clean frontend::clean mobile::clean
    rm -f data.db
